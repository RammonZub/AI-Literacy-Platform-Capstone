# ========================================
# AI Literacy Platform — Environment Variables
# ========================================
# This file documents the environment variables used by the application.
# Required services: Supabase (database + auth), Stripe (payments).

# ========================================
# Supabase — database and authentication
# ========================================
# Source: Supabase project API settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ========================================
# Application URLs
# ========================================
# Base URL used for auth redirects, checkout callbacks, and sitemap generation.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ========================================
# Stripe — checkout and payment processing
# ========================================
# Source: Stripe API keys.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key

# Webhook signing secret.
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe product and price IDs.
STRIPE_PRODUCT_ID=prod_your-product-id
STRIPE_PRICE_ID_1WEEK=price_your-1week-price-id
STRIPE_PRICE_ID_4WEEK=price_your-4week-price-id
STRIPE_PRICE_ID_12WEEK=price_your-12week-price-id
STRIPE_PRICE_ID_LIFETIME=price_your-lifetime-price-id

# Optional coupon IDs for checkout discounts.
STRIPE_DEFAULT_COUPON_ID=
STRIPE_TESTING_COUPON_ID=
STRIPE_ALLOW_PROMO_CODES=true

